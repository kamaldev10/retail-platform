{
  "name": "retail-platform",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "npm run db:generate",
    "start": "nx run-many --target=dev --all",
    "start:admin": "nx dev @retail/admin-dashboard",
    "start:pos": "nx dev @retail/pos",
    "start:gasoline": "nx dev @retail/gasoline-web",
    "build": "nx run-many --target=build --all",
    "build:admin": "nx build @retail/admin-dashboard",
    "build:pos": "nx build @retail/pos",
    "build:gasoline": "nx build @retail/gasoline-web",
    "db:generate": "npm run db:generate --workspace=packages/database",
    "db:push": "npm run db:push --workspace=packages/database",
    "db:seed": "npm run db:seed --workspace=packages/database",
    "lint": "nx run-many --target=lint --all",
    "test": "nx run-many --target=test --all",
    "nx": "nx"
  },
  "devDependencies": {
    "@next/swc-wasm-web": "^16.2.11",
    "nx": "^20.0.0",
    "typescript": "^5.6.3"
  }
}
